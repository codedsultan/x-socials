# ============================================
# SERVER CONFIGURATION
# ============================================

# Node environment: development, staging, production, test
NODE_ENV=development

# Server port (default: 4000)
PORT=4000

# Server maintenance mode (true/false)
SERVER_MAINTENANCE=false

# API base URL (used for documentation and links)
API_BASE_URL=http://localhost:4000

# API route prefix (default: /api)
API_PREFIX=api

# ============================================
# SECURITY & AUTHENTICATION
# ============================================

# JWT Secret - MUST be at least 32 characters in production
JWT_SECRET=your-super-secret-jwt-key-min-32-chars-long
ADMIN_API_KEY=
# JWT expiration (examples: 7d, 24h, 30m)
JWT_EXPIRES_IN=7d

# CORS Configuration
CORS_ENABLED=true

# ============================================
# DATABASE CONFIGURATION
# ============================================

# Default database type: mongodb, postgres, mysql, sqlite
DEFAULT_DB=mongodb

# Database mode: split (per-model routing) or single (all models one DB)
DB_MODE=split

# --------------------------------------------
# MongoDB Configuration
# --------------------------------------------
MONGO_URI=mongodb://localhost:27017/x-socials
MONGO_DB_NAME=x-socials
# Timeout settings (in milliseconds)
MONGO_SOCKET_TIMEOUT_MS=30000
MONGO_SERVER_SELECTION_TIMEOUT_MS=30000

# --------------------------------------------
# PostgreSQL Configuration
# --------------------------------------------
PG_HOST=localhost
PG_PORT=5432
PG_DATABASE=x_socials
PG_USER=postgres
PG_PASSWORD=postgres
PG_SSL=false
PG_CLIENT=pg
PG_POOL_MIN=2
PG_POOL_MAX=10

# --------------------------------------------
# MySQL Configuration
# --------------------------------------------
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_DATABASE=x_socials
MYSQL_USER=root
MYSQL_PASSWORD=root
MYSQL_CLIENT=mysql2
# MySQL uses same pool settings as PostgreSQL
PG_POOL_MIN=2
PG_POOL_MAX=10

# --------------------------------------------
# SQLite Configuration
# --------------------------------------------
SQLITE_FILENAME=./data/database.sqlite
SQLITE_CLIENT=sqlite3

# ============================================
# API DOCUMENTATION (Swagger)
# ============================================

# Enable Swagger UI (true/false - defaults: dev=true, prod=false)
ENABLE_SWAGGER=true

# ============================================
# LOGGING
# ============================================

# Log retention in days (1-90, production only)
LOG_DAYS=30

# ============================================
# EMAIL SERVICE (SendGrid)
# ============================================

# SendGrid API Key
SENDGRID_API_KEY=your-sendgrid-api-key

# From email address for sent emails
SMTP_FROM=noreply@x-socials.com

# ============================================
# CLOUDINARY (File Uploads)
# ============================================

# Cloudinary cloud name
CLOUDINARY_CLOUD_NAME=your-cloud-name

# Cloudinary API Key
CLOUDINARY_API_KEY=your-api-key

# Cloudinary API Secret
CLOUDINARY_API_SECRET=your-api-secret

# ============================================
# PRODUCTION-SPECIFIC (Override for production)
# ============================================

# Production API URL (overrides API_BASE_URL in production)
PRODUCTION_API_URL=https://api.x-socials.com

# Staging API URL (overrides API_BASE_URL in staging)
STAGING_API_URL=https://staging-api.x-socials.com

# ============================================
# DEVELOPMENT-SPECIFIC (Local overrides)
# ============================================

# Create a .env.local file for local overrides (git ignored)
# Example .env.local:
# PORT=3000
# MONGO_URI=mongodb://localhost:27017/x-socials-dev
# JWT_SECRET=dev-secret-key

AUTO_MIGRATE=true 
# ============================================
# OPEN TELEMETRY / PROMETHEUS CONFIGURATION
# ============================================

# Prometheus metrics endpoint configuration
PROMETHEUS_METRICS_PORT=9464
PROMETHEUS_METRICS_ENDPOINT=/metrics

# Enable detailed tracing (default: false in development)
OTEL_ENABLE_TRACES=false

# ============================================
# MODERATION WEBHOOK
# ============================================

# Base URL of the FastAPI moderation service
MODERATOR_URL=http://localhost:8001

# Optional API key — must match MODERATOR_API_KEY on the FastAPI side
# Leave blank if FastAPI api_key setting is also blank (open, internal network)
MODERATOR_API_KEY=

# Set to false to disable webhook calls entirely (useful in test/CI environments)
MODERATOR_WEBHOOK_ENABLED=true

# Hard timeout for webhook HTTP calls in milliseconds.
# The Node.js write path never waits longer than this for FastAPI to acknowledge.
# FastAPI's reconciliation scan covers any items dropped due to timeout.
# Default: 200ms — enough for a healthy local/LAN connection, fails fast on outage.
MODERATOR_WEBHOOK_TIMEOUT_MS=200
